# ProofCoach Environment Configuration

# Anthropic API (for synthesis with Claude)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace (for model download)
HF_TOKEN=hf_...

# Weights & Biases (for training monitoring)
WANDB_API_KEY=...
WANDB_PROJECT=proofcoach
WANDB_ENTITY=calebnewtonusc

# vLLM API key (set when starting synthesis instances)
VLLM_API_KEY=proofcoach_synth_key

# Deployment API
API_SECRET_KEY=change_me_in_production

# Redis (for session state and student knowledge model)
REDIS_URL=redis://localhost:6379

# Model paths
MODEL_PATH=./checkpoints/proofcoach-final
SFT_CHECKPOINT=./checkpoints/proofcoach-sft/final
RL_CHECKPOINT=./checkpoints/proofcoach-rl/final

# Lean 4 configuration
LEAN4_TIMEOUT=10
LEAN4_WORKERS=8
LEAN4_SIMULATED=0  # Set to 1 for debugging without Lean 4

# Training configuration
MICRO_BATCH_SIZE=2
GRAD_ACCUM_STEPS=4
USE_GRADIENT_CHECKPOINTING=0

# Data directories
RAW_DATA_DIR=./data/raw
SYNTH_DATA_DIR=./data/synthesized
TRAIN_DATA_DIR=./data/train

# AoPS crawling (set to a real session cookie from browser)
# Optional: crawling works without auth but is rate-limited
AOPS_SESSION_COOKIE=
